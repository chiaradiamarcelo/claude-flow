# Ignore everything by default
*

# Config files
!.gitignore
!CLAUDE.md
!RTK.md
!refactor-catalog.md
!settings.json
!statusline-command.sh
!README.md

# Hooks
!hooks/
!hooks/rtk-rewrite.sh
!hooks/on-enter-worktree.sh
!hooks/worktree-warming.md

# Worktree dep-warming worker (global default)
!warm-deps.sh

# Commands
!commands/
!commands/*.md

# Agents
!agents/
!agents/*/
!agents/*/Agent.md

# Skills
!skills/
!skills/*/
!skills/*/SKILL.md

# Scripts
!scripts/
!scripts/*.sh

# Examples
!examples/
!examples/*.json

# Memory
!memory/
!memory/**
!MEMORY.md

# Docs (engineering findings / lab notebook)
!docs/
!docs/**

# Evals
!evals/
!evals/**
# ...but not the regenerable per-machine fingerprint cache or temp progress notes
evals/**/.eval-cache.json
evals/PROGRESS.md

# macOS junk — re-ignore everywhere (the broad !dir/** whitelists re-include it)
**/.DS_Store
