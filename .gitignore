# Ignore everything by default
*

# Config files
!.gitignore
!CLAUDE.md
!RTK.md
!refactor-catalog.md
!settings.json
!statusline-command.sh
!README.md
!reviewers.json

# Hooks
!hooks/
!hooks/rtk-rewrite.sh

# Commands
!commands/
!commands/*.md

# Agents
!agents/
!agents/*/
!agents/*/Agent.md

# Skills
!skills/
!skills/*/
!skills/*/SKILL.md

# Examples
!examples/
!examples/*.json

# Memory
!memory/
!memory/**
!MEMORY.md
